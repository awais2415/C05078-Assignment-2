@* Pages/Admin/DeleteGalleryImage.cshtml - Confirmation page for deleting a gallery image
   Shows image details and asks admin to confirm deletion *@

@page
@model HunzaHaven.Pages.Admin.DeleteGalleryImageModel
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "Admin")]

@{
    ViewData["Title"] = "Delete Gallery Image";
}

<header class="page-header">
    <h1>Delete Gallery Image</h1>
    <p>Are you sure you want to delete this gallery image?</p>
</header>

<section>
    <div class="admin-form-container">
        <div class="delete-confirm-card">
            <img src="~/images/@Model.GalleryImage.FileName"
                 alt="@Model.GalleryImage.AltText"
                 class="admin-preview-img" />
            <h3>@Model.GalleryImage.Caption</h3>
            <p><strong>Alt Text:</strong> @Model.GalleryImage.AltText</p>
            <p><strong>Display Order:</strong> @Model.GalleryImage.DisplayOrder</p>
        </div>

        <form method="post">
            <input type="hidden" asp-for="GalleryImage.Id" />
            <div class="admin-form-actions">
                <button type="submit" class="submit-btn btn-danger">Confirm Delete</button>
                <a href="/Admin/Admin" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</section>
