@* Pages/Admin/AddProperty.cshtml - Form to add a new property
   Allows admin to create a new property listing with image upload *@

@page
@model HunzaHaven.Pages.Admin.AddPropertyModel
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "Admin")]

@{
    ViewData["Title"] = "Add Property";
}

<header class="page-header">
    <h1>Add New Property</h1>
    <p>Fill in the details below to add a new property listing</p>
</header>

<section>
    <div class="admin-form-container">
        @* Form uses enctype multipart for file upload support *@
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="form-message error"></div>

            <div class="form-group">
                <label asp-for="Property.Name">Property Name *</label>
                <input asp-for="Property.Name" placeholder="e.g. Standard Room" />
                <span asp-validation-for="Property.Name" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Property.Description">Description *</label>
                <textarea asp-for="Property.Description" placeholder="Describe the property..."></textarea>
                <span asp-validation-for="Property.Description" class="field-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Property.PricePerNight">Price Per Night (&pound;) *</label>
                    <input asp-for="Property.PricePerNight" type="number" step="0.01" min="1" />
                    <span asp-validation-for="Property.PricePerNight" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Property.MaxGuests">Max Guests *</label>
                    <input asp-for="Property.MaxGuests" type="number" min="1" max="20" />
                    <span asp-validation-for="Property.MaxGuests" class="field-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Property.RoomType">Room Type</label>
                <select asp-for="Property.RoomType">
                    <option value="">Select type...</option>
                    <option value="Standard">Standard</option>
                    <option value="Deluxe">Deluxe</option>
                    <option value="Family">Family</option>
                    <option value="Budget">Budget</option>
                    <option value="Premium">Premium</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="Property.IsAvailable">Available for Booking</label>
                <input asp-for="Property.IsAvailable" type="checkbox" class="admin-checkbox" />
            </div>

            @* Image upload field *@
            <div class="form-group">
                <label for="ImageUpload">Upload Image</label>
                <input type="file" id="ImageUpload" name="ImageUpload" accept="image/*" class="file-input" />
                <span class="field-hint">Accepted formats: JPG, PNG, GIF. Max 5MB.</span>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="submit-btn">Add Property</button>
                <a href="/Admin/Admin" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</section>
