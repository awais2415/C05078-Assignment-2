@* Pages/Admin/DeleteProperty.cshtml - Confirmation page for deleting a property
   Shows property details and asks admin to confirm deletion *@

@page
@model HunzaHaven.Pages.Admin.DeletePropertyModel
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "Admin")]

@{
    ViewData["Title"] = "Delete Property";
}

<header class="page-header">
    <h1>Delete Property</h1>
    <p>Are you sure you want to delete this property?</p>
</header>

<section>
    <div class="admin-form-container">
        @* Display the property details for confirmation *@
        <div class="delete-confirm-card">
            @if (!string.IsNullOrEmpty(Model.Property.ImageFileName))
            {
                <img src="~/images/@Model.Property.ImageFileName"
                     alt="@Model.Property.Name"
                     class="admin-preview-img" />
            }
            <h3>@Model.Property.Name</h3>
            <p>@Model.Property.Description</p>
            <p><strong>Price:</strong> &pound;@Model.Property.PricePerNight per night</p>
            <p><strong>Max Guests:</strong> @Model.Property.MaxGuests</p>
            <p><strong>Room Type:</strong> @Model.Property.RoomType</p>
        </div>

        @* Confirmation form - POST request triggers the deletion *@
        <form method="post">
            <input type="hidden" asp-for="Property.Id" />
            <div class="admin-form-actions">
                <button type="submit" class="submit-btn btn-danger">Confirm Delete</button>
                <a href="/Admin/Admin" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</section>
