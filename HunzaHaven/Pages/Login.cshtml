@* Pages/Login.cshtml - Admin login page
   Provides a login form for admin users to access the admin area *@

@page
@model HunzaHaven.Pages.LoginModel

@{
    ViewData["Title"] = "Admin Login";
}

@* ---- PAGE HEADER ---- *@
<header class="page-header">
    <h1>Admin Login</h1>
    <p>Sign in to manage properties and gallery images</p>
</header>

@* ---- LOGIN FORM SECTION ---- *@
<section>
    <div class="login-container">
        <div class="login-box">
            <h2>Sign In</h2>

            @* Display error message if login failed *@
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="form-message error" role="alert">@Model.ErrorMessage</div>
            }

            @* Login form - posts credentials to the server *@
            <form method="post">
                <div class="form-group">
                    <label asp-for="Email">Email Address</label>
                    <input asp-for="Email" type="email" placeholder="JNumber@chester.ac.uk" required />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password" type="password" placeholder="Enter your password" required />
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <button type="submit" class="submit-btn">Login</button>
            </form>
        </div>
    </div>
</section>
