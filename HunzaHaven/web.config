<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config - IIS configuration for ASP.NET Core hosting
  This file tells IIS to forward all requests to the ASP.NET Core application.
  Without this file, IIS only serves static files and returns 404 for Razor Pages.
  Code adapted from Microsoft, 2024
  https://learn.microsoft.com/en-us/aspnet/core/host-and-deploy/iis/web-config
-->
<configuration>
    <location path="." inheritInChildApplications="false">
        <system.webServer>
            <!-- ASP.NET Core Module handles all requests -->
            <handlers>
                <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
            </handlers>
            <!-- Configure the ASP.NET Core hosting model -->
            <aspNetCore processPath="dotnet"
                        arguments=".\HunzaHaven.dll"
                        stdoutLogEnabled="false"
                        stdoutLogFile=".\logs\stdout"
                        hostingModel="InProcess" />
        </system.webServer>
    </location>
</configuration>
<!--End of adapted code-->